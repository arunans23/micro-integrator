[server]
hostname = "localhost"
hot_deployment = "true"

[user_store]
type = "read_only_ldap"

[keystore.primary]
file_name = "repository/resources/security/wso2carbon.p12"
password = "wso2carbon"
alias = "wso2carbon"
key_password = "wso2carbon"
type = "PKCS12"

[truststore]
file_name = "repository/resources/security/client-truststore.p12"
password = "wso2carbon"
alias = "symmetric.key.value"
algorithm = "AES"
type = "PKCS12"

[management_api.jwt_token_security_handler]
enable = false

## Mariadb
[[datasource]]
id = "WSO2_COORDINATION_DB"
url = "jdbc:mysql://localhost:3309/clusterdbIntegrationTests?useSSL=false&amp;allowPublicKeyRetrieval=true"
username = "root"
password = "root"
driver = "com.mysql.jdbc.Driver"
